# ─────────────────────────────────────────────────────────────────────────────
# Nuvault server environment template.
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# The server refuses to boot if any REQUIRED key below is missing/empty.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ────────────────────────────────────────────────────────────────

# MongoDB connection string. Use either form:
#
#   Local development (no auth):
#     MONGO_URI=mongodb://127.0.0.1:27017/nuvaultDB
#
#   MongoDB Atlas (cloud, SRV record + TLS + auth):
#     MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/nuvaultDB?retryWrites=true&w=majority&appName=<appName>
#
# When using Atlas, allowlist the server's public IP (or 0.0.0.0/0 for a
# dev laptop) under Network Access in the Atlas console, otherwise the
# driver will hang on startup.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/nuvaultDB?retryWrites=true&w=majority&appName=<appName>

# Secret used to sign JWTs. Use a long, random string (32+ chars).
JWT_SECRET=

# JWT lifetime (e.g. 30d, 7d, 24h).
JWT_EXPIRE=

# Gemini AI key (aistudio.google.com).
# To rotate across multiple free-tier accounts, supply a comma-separated
# list of keys — Nuvault will move to the next key automatically when one
# is rate-limited (HTTP 429), and skip known-exhausted keys for ~60s.
#   Single key:    GEMINI_API_KEY=AIz...abc
#   Rotation set:  GEMINI_API_KEY=AIz...abc,AIz...def,AIz...ghi
GEMINI_API_KEY=

# ExchangeRate API key for currency conversion (exchangerate-api.com).
EXCHANGERATE_API_KEY=

# Allowed browser origin(s) for CORS + CSP connect-src. Comma-separated.
#   Local single-port server: http://localhost:5001
#   Vite dev server:          http://localhost:5173
#   Add your deployed origin (e.g. https://nuvault.vercel.app) when live.
CLIENT_ORIGIN=http://localhost:5001,http://localhost:5173

# ── Optional (have safe defaults) ─────────────────────────────────────────────

# Port the API/server listens on. Defaults to 5000 when unset.
PORT=5001

# development | production | test. Defaults to development.
# Rate limiters are disabled when NODE_ENV=test.
NODE_ENV=development
